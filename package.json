{
  "name": "tiny-tripper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "dotenvx run --convention=nextjs -- vite dev",
    "dev:backend": "dotenvx run --convention=nextjs -- convex dev",
    "predev": "dotenvx run --convention=nextjs -- convex dev --until-success && convex dashboard",
    "build": "dotenvx run --convention=nextjs -- vite build",
    "start": "dotenvx run --convention=nextjs -- node .output/server/index.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "upload-embeddings": "dotenvx run --convention=nextjs -- tsx scripts/upload-embeddings-batch.ts",
    "merge-embeddings": "dotenvx run --convention=nextjs -- tsx scripts/merge-embeddings.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.60.0",
    "@clerk/tanstack-react-start": "^1.4.19",
    "@convex-dev/geospatial": "^0.1.9",
    "@convex-dev/react-query": "^0.1.0",
    "@convex-dev/workflow": "^0.2.7",
    "@dotenvx/dotenvx": "^1.52.0",
    "@googlemaps/js-api-loader": "^1.16.10",
    "@mendable/firecrawl-js": "^4.12.0",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@radix-ui/themes": "^3.3.0",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.28",
    "convex": "^1.31.7",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^0.542.0",
    "openai": "^6.18.0",
    "posthog-js": "^1.342.1",
    "posthog-node": "^5.24.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.19.32",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "nitro": "3.0.260610-beta",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
